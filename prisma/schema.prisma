generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("client") // "client" | "superadmin" | "admin"
  products  String   @default("")       // comma-separated: "pro,flipbook"
  status    String   @default("active") // "active" | "suspended"
  token     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chatMessages ChatMessage[]
  projects     Project[]
  sentMessages AdminMessage[]  @relation("SentMessages")
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String   // "user" | "assistant"
  content   String
  agent     String   @default("nyxia") // "nyxia" | "copywriter" | "formation" | "seo"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String   @default("")
  type        String   @default("autre") // "livre" | "formation" | "site" | "copywriting" | "seo" | "marketing" | "autre"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdminMessage {
  id        String   @id @default(cuid())
  senderId  String
  content   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  sender User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
}
